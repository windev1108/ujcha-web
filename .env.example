# API NestJS (ujcha/apps/api) — CORS phải cho phép origin của web
NEXT_PUBLIC_API_URL=http://localhost:5000

# Google OAuth Web Client ID — trùng audience với GOOGLE_CLIENT_ID trên API
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# URL công khai của web app — BẮT BUỘC đặt đúng domain production để OG/meta image hoạt động
# Nếu sai (localhost) thì ảnh preview trên Messenger/Facebook sẽ không load được
NEXT_PUBLIC_SITE_URL=https://your-domain.com
